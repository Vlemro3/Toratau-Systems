# Переменные для docker-compose (копируйте в .env в корне проекта)
# SECRET_KEY=change-me-in-production
# SUPERADMIN_LOGIN=superadmin
# SUPERADMIN_PASSWORD=superadmin123

# Модуль смет (OpenAI — не используется, оставлен для совместимости)
OPENAI_API_KEY=sk-...
OPENAI_ESTIMATE_MODEL=gpt-4.1

# Модуль смет (Anthropic Claude): ключ и модель для проверки/анализа
# Получить ключ: https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_ESTIMATE_MODEL=claude-sonnet-4-20250514

# DaData API — автозаполнение реквизитов по ИНН и БИК
# Получить ключ: https://dadata.ru/profile/#info (бесплатно 10 000 запросов/день)
DADATA_API_KEY=

# Точка Банк — интернет-эквайринг
# JWT-токен: ЛК Точка → Сервисы → Интеграции и API → Сгенерировать JWT-ключ
TOCHKA_JWT_TOKEN=
# customerCode определяется автоматически через API, но можно указать вручную
TOCHKA_CUSTOMER_CODE=
# merchantId — нужен только если несколько торговых точек
TOCHKA_MERCHANT_ID=
# Секрет для проверки подписи webhook (опционально)
TOCHKA_WEBHOOK_SECRET=
# URL вебхука для получения уведомлений об оплате (должен быть HTTPS, порт 443)
TOCHKA_WEBHOOK_URL=https://программадлястроителей.рф/api/tochka/webhook
# URL для редиректа покупателя после оплаты
TOCHKA_REDIRECT_URL=https://программадлястроителей.рф/billing?payment=success
TOCHKA_FAIL_REDIRECT_URL=https://программадлястроителей.рф/billing?payment=fail
