# Переменные для docker-compose (копируйте в .env в корне проекта)
# SECRET_KEY=change-me-in-production
# SUPERADMIN_LOGIN=superadmin
# SUPERADMIN_PASSWORD=superadmin123

# Модуль смет (OpenAI): ключ и модель
OPENAI_API_KEY=sk-...
OPENAI_ESTIMATE_MODEL=gpt-4.1

# Точка Банк — интернет-эквайринг
# JWT-токен: ЛК Точка → Сервисы → Интеграции и API → Сгенерировать JWT-ключ
TOCHKA_JWT_TOKEN=
# customerCode определяется автоматически через API, но можно указать вручную
TOCHKA_CUSTOMER_CODE=
# merchantId — нужен только если несколько торговых точек
TOCHKA_MERCHANT_ID=
# Секрет для проверки подписи webhook (опционально)
TOCHKA_WEBHOOK_SECRET=
# URL для редиректа покупателя после оплаты
TOCHKA_REDIRECT_URL=https://app.example.com/billing?payment=success
TOCHKA_FAIL_REDIRECT_URL=https://app.example.com/billing?payment=fail
